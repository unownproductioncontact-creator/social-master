# --- Base de données (Supabase) ---
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# --- Auth maison (session JWT signée) ---
# Générer avec: openssl rand -base64 32
AUTH_SECRET=""

# --- Chiffrement des tokens OAuth (AES-256-GCM, doit décoder en exactement 32 octets) ---
# Générer avec: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# --- URL publique de l'app ---
APP_URL="https://scheduler.dokkanessentials.com"

# --- Meta / Instagram (developers.facebook.com, app type Business) ---
META_APP_ID=""
META_APP_SECRET=""

# --- TikTok (developers.tiktok.com) ---
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# --- Telegram (notifications) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
